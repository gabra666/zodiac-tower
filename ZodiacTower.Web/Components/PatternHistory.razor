<div class="pattern-history" aria-label="Historial completo de patrones">
    <div class="pattern-heading">
        <span>Patrones usados</span>
        <strong>@Steps.Count pasos</strong>
    </div>
    <div class="pattern-sequence">
        @foreach (var step in Steps)
        {
            <div class="pattern-step">
                <svg viewBox="0 0 54 52" role="img" aria-label="Lados activos @ActiveSideText(step)">
                    <polygon class="pattern-hex" points="27,3 48,15 48,37 27,49 6,37 6,15" />
                    @for (var side = 0; side < SidePositions.Length; side++)
                    {
                        var position = SidePositions[side];
                        <circle class="@(step.ActiveSides.Contains(side) ? "pattern-dot active" : "pattern-dot")"
                                cx="@position.X" cy="@position.Y" r="4.5" />
                    }
                </svg>
                <span>@(step.DistributedAt == 0 ? "Inicio" : $"Tras {step.DistributedAt} pts")</span>
                <strong>@ActiveSideText(step)</strong>
            </div>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public IReadOnlyList<PatternStep> Steps { get; set; } = Array.Empty<PatternStep>();

    private static readonly (int X, int Y)[] SidePositions =
    {
        (27, 5), (47, 16), (47, 36), (27, 47), (7, 36), (7, 16)
    };

    private static string ActiveSideText(PatternStep step) =>
        string.Join(", ", step.ActiveSides.Select(side => side + 1));
}
